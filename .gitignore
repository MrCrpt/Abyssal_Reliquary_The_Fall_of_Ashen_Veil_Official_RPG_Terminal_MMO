# ============================================================
# Abyssal Reliquary: The Fall of Ashen Veil
# Official RPG Terminal MMO
# Git ignore rules
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.Python
pythonenv/
venv/
.venv/
env/
ENV/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
.eggs/
dist-info/

# ------------------------------------------------------------
# PyInstaller / build output
# ------------------------------------------------------------
build/
dist/
*.spec
*.manifest
*.log
*.tmp

# ------------------------------------------------------------
# Lua
# ------------------------------------------------------------
*.luac
*.rock
*.rockspec.lock
.luarocks/
lua_modules/
.luacheckcache
.lua_history

# LuaRocks local trees
rocks/
rocks-*/
.lock-wscript

# Love2D / Lua packaged builds
*.love

# ------------------------------------------------------------
# Node/Electron/JS noise if someone experiments later
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# ARTFOAV runtime / saves / local server state
# ------------------------------------------------------------
runtime/
runtime/*
!runtime/.keep
!runtime/logs/
!runtime/logs/.keep

saves/
saves/*
!saves/.keep

legacy_saves/
legacy_saves/*
!legacy_saves/PUT_OLD_SAVES_HERE.txt

imported_original_saves/
imported_original_saves/*
!imported_original_saves/.keep

server_worlds/
server_worlds/*
!server_worlds/README_SERVER_WORLDS.txt
!server_worlds/default/
!server_worlds/default/.keep
!server_worlds/default/accounts/
!server_worlds/default/accounts/.keep
!server_worlds/default/sessions/
!server_worlds/default/sessions/.keep

server_logs/
server_logs/*
!server_logs/.keep

tester_reports/
tester_reports/*
!tester_reports/.keep

# ------------------------------------------------------------
# Local configs / secrets
# ------------------------------------------------------------
runtime/server_login.json
runtime/server_config.json
runtime/multiplayer_status.json
runtime/live_state.json
runtime/audio_events_queue.jsonl
runtime/audio_event_cursor.txt
runtime/asset_manifest.json
runtime/save_validation.json

# Keep default config in repo, ignore local overrides if created later.
config/local_settings.json
config/secrets.json

# ------------------------------------------------------------
# Audio assets: keep folder structure, avoid accidentally committing huge custom packs
# ------------------------------------------------------------
custom/sounds/*
!custom/sounds/PUT_CUSTOM_SOUND_HERE.txt
!custom/sounds/sfx/
custom/sounds/sfx/*
!custom/sounds/sfx/.keep

# Built-in assets can be committed intentionally.
# If the repo should avoid large audio, uncomment:
# assets/sounds/*.mp3
# assets/sounds/*.mp4
# assets/sounds/*.wav
# assets/sounds/*.ogg
# assets/sounds/*.flac

# ------------------------------------------------------------
# OS/editor junk
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# Archives / release zips
# ------------------------------------------------------------
*.zip
*.7z
*.rar
*.tar
*.tar.gz
